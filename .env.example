# Lokal kann die App ohne DATABASE_URL mit SQLite laufen.
# Für Supabase: Settings > Database > Connection string > URI kopieren.
# Beispiel: postgresql://postgres.PROJECT:PASS@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Für /admin/login
ADMIN_PASSWORD=bitte-aendern

# Flask Session Key
SECRET_KEY=bitte-langes-zufaelliges-secret

# Tipp-Lock: Eröffnungsspiel 11.06.2026, 21:00 Europe/Berlin = 19:00 UTC
PREDICTION_LOCK_AT=2026-06-11T19:00:00Z

# Optional: wird auf jeder Anfrage angezeigt.
APP_NAME=WM 2026 Tippspiel
